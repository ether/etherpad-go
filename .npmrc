# Pin the default npm registry to public npmjs.
#
# Dependabot's environment otherwise routes npm resolution through GitHub
# Packages (npm.pkg.github.com), which serves stale metadata for some packages
# (e.g. @types/react-dom maxes out at 17.0.11 there) and makes pnpm fail the
# recursive lockfile update with ERR_PNPM_NO_MATCHING_VERSION instead of
# falling back to npmjs. An explicit registry here keeps resolution on npmjs
# in every environment (local, CI, Dependabot). No-op locally/CI since npmjs
# is already the default.
registry=https://registry.npmjs.org/
