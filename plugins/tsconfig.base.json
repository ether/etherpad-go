{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "isolatedModules": true,
    "allowJs": false,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "../typings/**/*.d.ts",
    "./**/static/js/**/*.ts"
  ]
}
