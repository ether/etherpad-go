{
  "name": "etherpad-go-workspace",
  "private": true,
  "packageManager": "pnpm@10.17.1",
  "scripts": {
    "typecheck": "pnpm run typecheck:ui && pnpm run typecheck:admin && pnpm run typecheck:playwright && pnpm run typecheck:plugins",
    "typecheck:ui": "pnpm --filter ./ui exec tsc --noEmit",
    "typecheck:admin": "pnpm --filter ./admin exec tsc --noEmit",
    "typecheck:playwright": "pnpm --filter ./playwright exec tsc --noEmit",
    "typecheck:plugins": "pnpm -r --filter ./plugins/* exec tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "etherpad-webcomponents": "^0.0.9"
  }
}
